ar siguiente\n","            if i + 1 < len(tokens):\n","\n","                nxt = tokens[i + 1]\n","\n","                # caso VCV\n","                if nxt not in VOWELS:\n","\n","                    # mirar siguiente del siguiente\n","                    if i + 2 < len(tokens):\n","\n","                        nxt2 = tokens[i + 2]\n","\n","                        # VCV → dividir antes de consonante\n","                        if nxt2 in VOWELS:\n","                            syllables.append(current)\n","                            current = []\n","\n","                        # VCCV\n","                        else:\n","\n","                            # coda válida\n","                            if nxt in CODAS:\n","                                current.append(nxt)\n","                                syllables.append(current)\n","                                current = []\n","                                i += 1\n","                            else:\n","                                syllables.append(current)\n","                                current = []\n","\n","                    else:\n","                        # final\n","                        if nxt in CODAS:\n","                            current.append(nxt)\n","                            i += 1\n","\n","            syllables.append(current)\n","            current = []\n","\n","        i += 1\n","\n","    if current:\n","        syllables.append(current)\n","\n","    return [''.join(s) for s in syllables]"],"metadata":{"id":"J2e-qwUDnGtH","executionInfo":{"status":"ok","timestamp":1778736838239,"user_tz":300,"elapsed":7,"user":{"displayName":"MIGUEL ANGEL PAUCAR NAVARRO","userId":"16462703347708425740"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["def silabificar_texto(texto):\n","    \"\"\"\n","    El silabificador trabaja palabra por palabra.\n","\n","    Cada palabra:\n","    palabra → sílabas\n","\n","    Luego todas las sílabas se unen\n","    en una sola s